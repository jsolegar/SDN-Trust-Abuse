# =========================================================
# SDN Trust Abuse - Custom Snort Rules
# File: /etc/snort/rules/Myrules.rules
# =========================================================

# --- ICMP Flood externo ---
alert icmp 10.0.0.10 any -> $HOME_NET any (msg:"External ICMP Flood detected"; threshold: type both, track by_src, count 50, seconds 1; sid:11000001; rev:3;)

# --- TCP Flood externo ---
alert tcp 10.0.0.10 any -> $HOME_NET any (msg:"External TCP Flood detected"; threshold: type both, track by_src, count 200, seconds 1; sid:11000009; rev:3;)

# --- Port Scan Detection (excluye h2) ---
alert tcp !10.0.0.20 any -> $HOME_NET any (msg:"Nmap SYN Scan detected"; flags:S; threshold: type both, track by_src, count 20, seconds 2; sid:11000002; rev:2;)
alert tcp !10.0.0.20 any -> $HOME_NET any (msg:"Port Scan - multiple ports"; flags:S; threshold: type both, track by_src, count 15, seconds 5; sid:11000003; rev:2;)

# --- SSH Scan Detection ---
alert tcp any any -> $HOME_NET 22 (msg:"SSH Port Scan detected"; flags:S; threshold: type both, track by_src, count 4, seconds 3; sid:11000004; rev:5;)

# --- SSH Brute Force ---
alert tcp any any -> $HOME_NET 22 (msg:"SSH Brute Force detected"; flow:established; threshold: type both, track by_src, count 3, seconds 30; sid:11000005; rev:5;)

# --- Internal DoS h2 -> h3 ---
alert icmp 10.0.0.20 any -> 10.0.0.30 any (msg:"Internal ICMP Flood h2 to h3"; threshold: type both, track by_src, count 30, seconds 1; sid:11000006; rev:2;)
alert tcp 10.0.0.20 any -> 10.0.0.30 any (msg:"Internal TCP Flood h2 to h3"; threshold: type both, track by_src, count 50, seconds 1; sid:11000007; rev:2;)
